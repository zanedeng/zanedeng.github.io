{
  "$schema": "https://unpkg.com/@changesets/config@2.1.1/schema.json",
  "changelog": [
    "@changesets/changelog-github",
    {
      "repo": "zanedeng/zanedeng.github.io"
    }
  ],
  "commit": false,
  "fixed": [],
  "linked": [],
  "ignore": [
    "@zanejs/docs",
