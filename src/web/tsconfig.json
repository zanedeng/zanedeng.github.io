{
  "compileOnSave": true,
  "compilerOptions": {
    //指定生成哪个模块系统代码：'commonjs'，'amd'，'system'，或 'umd'或'es2015'。只有'amd'和'system'能和--outFile一起使用。当目标是ES5或以下的时候不能使用'es2015'。
    "module": "commonjs",
    //指定ECMAScript目标版本'ES3' (默认)，'ES5'，或'ES6'
    "target": "es5",
    //在表达式和声明上有隐含的'any'类型时报错。
    "noImplicitAny": false,
    //删除所有注释，除了以/!*开头的版权信息。
    "removeComments": true,
    //将输出文件合并为一个文件。合并的顺序是根据传入编译器的文件顺序和///<reference``>和import的文件顺序决定的。
    "outFile": "../../dist/zane.web.gt.js",
    //生成相应的'.d.ts'文件。
    "declaration": true,
    //当生成文件时指定行结束符：'CRLF'（dos）或 'LF' （unix）。
    "newLine": "LF",
    //不把/// <reference``>或模块导入的文件加到编译文件列表。
    "noResolve": false,
    //报错时不生成输出文件。
    "noEmitOnError": false,
    //不包含默认的库文件（lib.d.ts）。
    "noLib":false,
    //将代码与sourcemaps生成到一个文件中，要求同时设置了--inlineSourceMap或--sourceMap属性。
    "inlineSources": true,
    //生成相应的'.map'文件。
    "sourceMap": true
  },
  "exclude": [
    "../../dist/",
    "../../www/"
  ]
}